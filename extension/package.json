{
  "name": "@magpie/extension",
  "version": "1.0.0",
  "description": "Magpie Chrome Extension - Save interesting links with one click",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "npm run clean && vite build --mode production && npm run copy:manifest && npm run copy:icons",
    "build:dev": "npm run clean && vite build --mode development && npm run copy:manifest && npm run copy:icons",
    "build:full": "npm run generate:icons && npm run build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist",
    "copy:manifest": "cp src/manifest.json dist/",
    "copy:icons": "cp -r icons dist/",
    "generate:icons": "node scripts/generate-icons.js",
    "package": "node scripts/package-extension.cjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "postcss": "^8.5.10",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-web-extension": "^4.5.1",
    "vitest": "^1.6.1"
  }
}
